{
  "manifest_version": 2,
  "name": "ReplyAI",
  "description": "A basic Hello World example extension!",
  "version": "1.0",
  "author": "Thunderbird Team",
  "browser_specific_settings": {
    "gecko": {
      "id": "helloworld@yoursite.com",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "messagesRead",
    "compose",
    "tabs",
    "storage",
    "activeTab",
    "accountsRead",
    "identity"
  ],
  "browser_action": {
    "default_popup": "mainPopup/popup.html",
    "default_title": "Hello World",
    "default_icon": "images/internet-32px.png"
  },
  "message_display_action": {
    "default_popup": "messagePopup/popup.html",
    "default_title": "Reply with AI",
    "default_icon": "images/internet-32px.png"
  },
  "compose_action": {
    "default_popup": "composePopup/popupV2.html",
    "default_title": "Generate Response",
    "default_icon": "images/internet-32px.png"
  },
  "icons": {
    "64": "images/internet.png",
    "32": "images/internet-32px.png",
    "16": "images/internet-16px.png"
  }
}