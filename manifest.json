{
  "manifest_version": 2,
  "name": "ReplyAgent",
  "description": "Extension generates AI responses using user's api key",
  "version": "1.1",
  "author": "ReplyAgentTeam",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "replyagentteam@gmail.com",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "messagesRead",
    "compose",
    "tabs",
    "storage",
    "activeTab",
    "accountsRead",
    "identity"
  ],
  "browser_action": {
    "default_popup": "mainPopup/main.html",
    "default_title": "ReplyAgent",
    "default_icon": "images/logo.png"
  },
  "message_display_action": {
    "default_popup": "messagePopup/message.html",
    "default_title": "Anti Spam",
    "default_icon": "images/logo.png"
  },
  "compose_action": {
    "default_popup": "composePopup/compose.html",
    "default_title": "Generate Response",
    "default_icon": "images/logo.png"
  },
  "icons": {
    "64": "images/logo_64.png",
    "32": "images/logo_32.png",
    "16": "images/logo_16.png"
  }
}